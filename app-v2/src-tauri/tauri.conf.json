{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AIDevHub",
  "version": "0.4.5",
  "identifier": "com.aidevhub.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AIDevHub",
        "width": 1120,
        "height": 720
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": "v1Compatible",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "hooks.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/LZY-Ricardo/AIDevHub/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI0RjY3Qjc4ODg2MkYwNEEKUldSSzhHS0llSHYySkMwVTVodVNadlBYYXlmaW9XOWtHMEUrN1p6cHNvaVYrNVh3U1QvakV6Q0sK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
